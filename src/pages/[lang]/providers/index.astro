---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import { getAllProviders } from '../../../data/loader'

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }]
}

const { lang } = Astro.params
const providers = getAllProviders()
const isZh = lang === 'zh'

const title = isZh ? '基础设施厂商' : 'Infrastructure Providers'
const desc = isZh
  ? `收录 ${providers.length} 家云厂商及 PaaS 平台，含新用户活动套餐，助你选择最优部署方案。`
  : `${providers.length} cloud providers and PaaS platforms with current deals for deploying OpenClaw-compatible agents.`

const typeLabel = {
  'public-cloud': isZh ? '公有云' : 'Public Cloud',
  'paas': 'PaaS',
  'operator': isZh ? '运营商云' : 'Operator Cloud',
}
const typeColor = {
  'public-cloud': '#60a5fa',
  'paas': '#a78bfa',
  'operator': '#fb923c',
}

const eligibleLabel = {
  new: isZh ? '新用户' : 'New Users',
  all: isZh ? '全部用户' : 'All Users',
  member: isZh ? '会员' : 'Members',
  enterprise: isZh ? '企业' : 'Enterprise',
}

const periodLabel = {
  month: isZh ? '/月' : '/mo',
  year: isZh ? '/年' : '/yr',
  once: isZh ? '起' : '+',
}

function formatPrice(deal) {
  const symbol = deal.currency === 'usd' ? '$' : '¥'
  if (deal.price === 0) return isZh ? '免费' : 'Free'
  return `${symbol}${deal.price}${periodLabel[deal.period] ?? ''}`
}
---

<StarlightPage frontmatter={{ title, description: desc }}>
  <p style="color:var(--sl-color-gray-3);margin-bottom:1.5rem">{desc}</p>

  <!-- Filter buttons -->
  <div id="filters" class="not-content" style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.5rem">
    <button data-filter="all" class="flt active" onclick="filterProvider(this)">
      {isZh ? '全部' : 'All'} ({providers.length})
    </button>
    <button data-filter="public-cloud" class="flt" onclick="filterProvider(this)">
      {isZh ? '公有云' : 'Public Cloud'} ({providers.filter(p => p.type === 'public-cloud').length})
    </button>
    <button data-filter="operator" class="flt" onclick="filterProvider(this)">
      {isZh ? '运营商云' : 'Operator'} ({providers.filter(p => p.type === 'operator').length})
    </button>
    <button data-filter="paas" class="flt" onclick="filterProvider(this)">
      PaaS ({providers.filter(p => p.type === 'paas').length})
    </button>
    <button data-filter="deal-new" class="flt" onclick="filterProvider(this)">
      {isZh ? '有新用户优惠' : 'Has New-User Deal'} ({providers.filter(p => p.deals.some(d => d.eligible === 'new')).length})
    </button>
    <button data-filter="deal-free" class="flt" onclick="filterProvider(this)">
      {isZh ? '含免费层' : 'Free Tier'} ({providers.filter(p => p.deals.some(d => d.price === 0)).length})
    </button>
  </div>

  <!-- Provider list -->
  <div id="providerList" class="not-content" style="display:flex;flex-direction:column;gap:1.25rem">
    {providers.map(p => (
      <div
        class="provider-card"
        data-type={p.type}
        data-has-new={String(p.deals.some(d => d.eligible === 'new'))}
        data-has-free={String(p.deals.some(d => d.price === 0))}
        style="border:1px solid var(--sl-color-hairline);border-radius:0.75rem;overflow:hidden"
      >
        <!-- Header -->
        <div style={`display:flex;align-items:center;gap:0.75rem;padding:1rem 1.25rem;border-bottom:1px solid var(--sl-color-hairline);background:color-mix(in srgb, ${p.logo_color ?? '#888'} 8%, transparent)`}>
          <div style={`width:0.3rem;height:2rem;border-radius:2px;background:${p.logo_color ?? '#888'};flex-shrink:0`}></div>
          <div style="flex:1;min-width:0">
            <div style="display:flex;align-items:center;gap:0.6rem;flex-wrap:wrap">
              <span style="font-weight:700;font-size:1.05rem;color:var(--sl-color-white)">{p.name}</span>
              {p.name_en && p.name_en !== p.name && (
                <span style="font-size:0.8rem;color:var(--sl-color-gray-3)">{p.name_en}</span>
              )}
              <span style={`font-size:0.72rem;font-weight:600;padding:0.15rem 0.5rem;border-radius:999px;background:color-mix(in srgb, ${typeColor[p.type]} 20%, transparent);color:${typeColor[p.type]}`}>
                {typeLabel[p.type]}
              </span>
            </div>
            <p style="font-size:0.82rem;color:var(--sl-color-gray-2);margin:0.2rem 0 0">
              {isZh ? (p.description_zh ?? p.description) : (p.description ?? p.description_zh)}
            </p>
          </div>
          {p.website && (
            <a
              href={p.website}
              target="_blank"
              rel="noopener noreferrer"
              style="flex-shrink:0;font-size:0.78rem;color:var(--sl-color-accent);text-decoration:none;white-space:nowrap"
            >
              {isZh ? '官网 ↗' : 'Website ↗'}
            </a>
          )}
        </div>

        <!-- Deals table -->
        {p.deals && p.deals.length > 0 && (
          <div style="overflow-x:auto">
            <table style="width:100%;border-collapse:collapse;font-size:0.82rem">
              <thead>
                <tr style="color:var(--sl-color-gray-3);font-size:0.75rem;font-weight:500">
                  <th style="text-align:left;padding:0.6rem 1.25rem;border-bottom:1px solid var(--sl-color-hairline)">{isZh ? '套餐' : 'Plan'}</th>
                  <th style="text-align:left;padding:0.6rem 0.75rem;border-bottom:1px solid var(--sl-color-hairline);white-space:nowrap">{isZh ? '配置' : 'Specs'}</th>
                  <th style="text-align:right;padding:0.6rem 0.75rem;border-bottom:1px solid var(--sl-color-hairline);white-space:nowrap">{isZh ? '价格' : 'Price'}</th>
                  <th style="text-align:left;padding:0.6rem 0.75rem;border-bottom:1px solid var(--sl-color-hairline);white-space:nowrap">{isZh ? '资格' : 'Eligible'}</th>
                  <th style="text-align:left;padding:0.6rem 1.25rem 0.6rem 0.75rem;border-bottom:1px solid var(--sl-color-hairline)">{isZh ? '备注' : 'Note'}</th>
                </tr>
              </thead>
              <tbody>
                {p.deals.map((deal, i) => (
                  <tr style={i % 2 === 1 ? 'background:color-mix(in srgb,var(--sl-color-gray-6) 30%,transparent)' : ''}>
                    <td style="padding:0.6rem 1.25rem;color:var(--sl-color-white);font-weight:500;white-space:nowrap">
                      {deal.url
                        ? <a href={deal.url} target="_blank" rel="noopener noreferrer" style="color:var(--sl-color-accent);text-decoration:none">{isZh ? (deal.name_zh ?? deal.name) : deal.name}</a>
                        : (isZh ? (deal.name_zh ?? deal.name) : deal.name)
                      }
                      {deal.limited && <span style="margin-left:0.35rem;font-size:0.7rem;color:#f59e0b;font-weight:600">{isZh ? '限量' : 'Limited'}</span>}
                    </td>
                    <td style="padding:0.6rem 0.75rem;color:var(--sl-color-gray-2);white-space:nowrap">
                      {deal.cpu && deal.ram
                        ? `${deal.cpu}C ${deal.ram}G${deal.disk ? ` ${deal.disk}G` : ''}${deal.bandwidth ? ` ${deal.bandwidth}M` : ''}`
                        : (deal.product ?? '—')}
                    </td>
                    <td style="padding:0.6rem 0.75rem;text-align:right;font-weight:700;white-space:nowrap">
                      <span style={`color:${deal.price === 0 ? '#22c55e' : 'var(--sl-color-accent)'}`}>
                        {formatPrice(deal)}
                      </span>
                    </td>
                    <td style="padding:0.6rem 0.75rem;white-space:nowrap">
                      <span style={`font-size:0.72rem;padding:0.1rem 0.4rem;border-radius:4px;background:color-mix(in srgb,${deal.eligible === 'new' ? '#f59e0b' : '#6b7280'} 20%,transparent);color:${deal.eligible === 'new' ? '#f59e0b' : 'var(--sl-color-gray-2)'}`}>
                        {eligibleLabel[deal.eligible] ?? deal.eligible}
                      </span>
                    </td>
                    <td style="padding:0.6rem 1.25rem 0.6rem 0.75rem;color:var(--sl-color-gray-3);font-size:0.78rem">
                      {isZh ? (deal.note_zh ?? deal.note ?? '') : (deal.note ?? deal.note_zh ?? '')}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    ))}
  </div>

  <p style="margin-top:2rem;font-size:0.78rem;color:var(--sl-color-gray-4)">
    {isZh
      ? '⚠️ 活动套餐价格随时可能变化，以官网实时价格为准。verified_date 为社区最后确认日期。'
      : '⚠️ Deal prices may change at any time. Always verify on the provider\'s website. verified_date indicates last community check.'}
  </p>
</StarlightPage>

<style>
  .flt {
    border-radius: 0.5rem;
    border: 1px solid var(--sl-color-hairline);
    background: transparent;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    height: 2rem;
    padding: 0 0.85rem;
    box-sizing: border-box;
    font-size: 0.82rem;
    line-height: 1;
    transition: all .15s;
  }
  .flt.active, .flt:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
  }
</style>

<script>
  function filterProvider(btn) {
    document.querySelectorAll('.flt').forEach(b => b.classList.remove('active'))
    btn.classList.add('active')
    const f = btn.dataset.filter
    document.querySelectorAll('#providerList > .provider-card').forEach(el => {
      const show = f === 'all'
        || (f === 'public-cloud' && el.dataset.type === 'public-cloud')
        || (f === 'operator' && el.dataset.type === 'operator')
        || (f === 'paas' && el.dataset.type === 'paas')
        || (f === 'deal-new' && el.dataset.hasNew === 'true')
        || (f === 'deal-free' && el.dataset.hasFree === 'true')
      ;(el as HTMLElement).style.display = show ? '' : 'none'
    })
  }
  window.filterProvider = filterProvider
</script>
