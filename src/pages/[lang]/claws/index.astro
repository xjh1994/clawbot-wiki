---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import { getAllClaws } from '../../../data/loader'

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }]
}

const { lang } = Astro.params
const claws = getAllClaws()
const isZh = lang === 'zh'

const title = isZh ? '全部 Claw' : 'All Claws'
const desc = isZh
  ? `收录 ${claws.length} 款 OpenClaw 生态产品，社区维护，持续更新。`
  : `Tracking ${claws.length} products in the OpenClaw ecosystem. Community maintained.`

const dot = (level) => ({ yes: '✓', no: '✗', partial: '~', unknown: '?' }[level] ?? '?')
const dotColor = (level) => ({ yes: '#22c55e', no: '#ef4444', partial: '#eab308', unknown: '#6b7280' }[level] ?? '#6b7280')
const base = isZh ? '/zh' : '/en'

const categoryColors = {
  desktop: '#60a5fa', cloud: '#a78bfa', enterprise: '#fb923c',
  'open-source': '#4ade80', embedded: '#22d3ee', other: '#9ca3af',
}
---

<StarlightPage frontmatter={{ title, description: desc }}>
  <p style="color:var(--sl-color-gray-3);margin-bottom:1.5rem">{desc}</p>

  <!-- Filter buttons -->
  <div id="filters" class="not-content" style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.5rem">
    <button data-filter="all" class="flt active" onclick="filter(this)">
      {isZh ? '全部' : 'All'} ({claws.length})
    </button>
    <button data-filter="wechat" class="flt" onclick="filter(this)">
      WeChat ClawBot ({claws.filter(c => c.channels.wechat_clawbot === 'yes').length})
    </button>
    <button data-filter="open-source" class="flt" onclick="filter(this)">
      {isZh ? '开源' : 'Open Source'} ({claws.filter(c => c.category === 'open-source').length})
    </button>
    <button data-filter="verified" class="flt" onclick="filter(this)">
      {isZh ? '已验证' : 'Verified'} ({claws.filter(c => c.verified).length})
    </button>
  </div>

  <!-- Grid -->
  <div id="grid" class="not-content" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem">
    {claws.map(c => (
      <div
        data-href={`${base}/claws/${c.slug}/`}
        data-wechat={c.channels.wechat_clawbot}
        data-category={c.category}
        data-verified={String(c.verified)}
        class="claw-card"
        style="border:1px solid var(--sl-color-hairline);border-radius:0.75rem;padding:1.25rem;cursor:pointer;display:flex;flex-direction:column;transition:border-color .15s"
        onmouseover="this.style.borderColor='var(--sl-color-accent)'"
        onmouseout="this.style.borderColor='var(--sl-color-hairline)'"
        onclick="if(!event.target.closest('a'))location.href=this.dataset.href"
      >
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:0.5rem;margin-bottom:0.5rem">
          <div style="min-width:0;flex:1">
            <div style="font-weight:600;color:var(--sl-color-white);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{isZh ? c.name_zh : c.name}</div>
            <div style="font-size:0.8rem;color:var(--sl-color-gray-3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{isZh ? c.vendor_zh : c.vendor}</div>
          </div>
          <span style={`font-size:0.75rem;font-weight:600;color:${dotColor(c.channels.wechat_clawbot)};white-space:nowrap;flex-shrink:0`}>
            WeChat {dot(c.channels.wechat_clawbot)}
          </span>
        </div>
        <p style="font-size:0.82rem;color:var(--sl-color-gray-2);margin:0 0 0.75rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
          {isZh ? c.description_zh : c.description}
        </p>
        <div style="display:flex;gap:0.5rem;align-items:center;font-size:0.75rem;margin-top:auto">
          <span style={`color:${categoryColors[c.category] ?? '#9ca3af'};font-weight:500`}>{c.category}</span>
          {c.website && (
            <a
              href={c.website}
              target="_blank"
              rel="noopener noreferrer"
              style="margin-left:auto;color:var(--sl-color-accent);text-decoration:none;font-size:0.75rem"
            >
              {isZh ? '官网 ↗' : 'Website ↗'}
            </a>
          )}
          {!c.website && !c.verified && <span style="color:var(--sl-color-gray-5);margin-left:auto">{isZh ? '待验证' : 'unverified'}</span>}
        </div>
      </div>
    ))}
  </div>
</StarlightPage>

<style>
  .flt {
    border-radius: 0.5rem;
    border: 1px solid var(--sl-color-hairline);
    background: transparent;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    height: 2rem;
    padding: 0 0.85rem;
    box-sizing: border-box;
    font-size: 0.82rem;
    line-height: 1;
    transition: all .15s;
  }
  .flt.active, .flt:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
  }
</style>

<script>
  function filter(btn) {
    document.querySelectorAll('.flt').forEach(b => b.classList.remove('active'))
    btn.classList.add('active')
    const f = btn.dataset.filter
    document.querySelectorAll('#grid > .claw-card').forEach(el => {
      const show = f === 'all'
        || (f === 'wechat' && el.dataset.wechat === 'yes')
        || (f === 'open-source' && el.dataset.category === 'open-source')
        || (f === 'verified' && el.dataset.verified === 'true')
      el.style.display = show ? '' : 'none'
    })
  }
  window.filter = filter
</script>
