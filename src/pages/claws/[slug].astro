---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import { getAllClaws, getClawBySlug } from '../../data/loader'

export function getStaticPaths() {
  return getAllClaws().map(c => ({ params: { slug: c.slug } }))
}

const { slug } = Astro.params
const claw = getClawBySlug(slug)
if (!claw) return Astro.redirect('/claws/')

const name = claw.name_zh
const vendor = claw.vendor_zh
const description = claw.description_zh
const notes = claw.notes_zh

const dot = (l) => ({ yes: '✓', no: '✗', partial: '~', unknown: '?' }[l] ?? '?')
const dotColor = (l) => ({ yes: '#22c55e', no: '#ef4444', partial: '#eab308', unknown: '#6b7280' }[l] ?? '#6b7280')

const channels = [
  { key: 'wechat_clawbot', label: '💬 微信 ClawBot' },
  { key: 'qq',    label: '🐧 QQ' },
  { key: 'wecom', label: '🏢 企业微信' },
  { key: 'feishu',   label: '🪶 飞书' },
  { key: 'dingtalk', label: '📎 钉钉' },
  { key: 'telegram', label: '✈️ Telegram' },
  { key: 'discord',  label: '🎮 Discord' },
]
---

<StarlightPage frontmatter={{ title: `${name} — ${vendor}`, description }}>

  {!claw.verified && (
    <div style="border:1px solid #854d0e;background:#451a03;border-radius:0.5rem;padding:0.75rem 1rem;margin-bottom:1.5rem;font-size:0.85rem;color:#fde68a">
      ⚠️ 社区投稿，尚未验证
    </div>
  )}

  <p style="color:var(--sl-color-gray-2)">{description}</p>

  <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin:1.25rem 0">
    {claw.website && (
      <a href={claw.website} target="_blank" rel="noopener" style="font-size:0.85rem;padding:0.4rem 0.9rem;border:1px solid var(--sl-color-accent);border-radius:0.5rem;color:var(--sl-color-accent);text-decoration:none">
        官网 →
      </a>
    )}
    {claw.github && (
      <a href={claw.github} target="_blank" rel="noopener" style="font-size:0.85rem;padding:0.4rem 0.9rem;border:1px solid var(--sl-color-hairline);border-radius:0.5rem;color:var(--sl-color-gray-2);text-decoration:none">
        GitHub →
      </a>
    )}
    <a
      href={`https://github.com/xjh1994/clawbot-wiki/edit/main/src/data/claws/${slug}.yaml`}
      target="_blank" rel="noopener"
      style="font-size:0.85rem;padding:0.4rem 0.9rem;border:1px solid var(--sl-color-hairline);border-radius:0.5rem;color:var(--sl-color-gray-3);text-decoration:none;margin-left:auto"
    >
      ✏️ 编辑此页
    </a>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1rem;margin-top:1.5rem">

    <div style="border:1px solid var(--sl-color-hairline);border-radius:0.75rem;padding:1.25rem">
      <h3 style="margin:0 0 1rem;font-size:0.95rem">渠道兼容性</h3>
      {channels.map(({ key, label }) => (
        <div style="display:flex;justify-content:space-between;align-items:center;padding:0.35rem 0;border-bottom:1px solid var(--sl-color-hairline-light)">
          <span style="font-size:0.85rem;color:var(--sl-color-gray-2)">{label}</span>
          <span style={`font-weight:600;color:${dotColor(claw.channels[key])}`}>{dot(claw.channels[key])}</span>
        </div>
      ))}
    </div>

    <div style="border:1px solid var(--sl-color-hairline);border-radius:0.75rem;padding:1.25rem">
      <h3 style="margin:0 0 1rem;font-size:0.95rem">OpenClaw</h3>
      {[
        ['协议兼容', claw.openclaw.protocol_compat],
        ['分支类型', claw.openclaw.fork_type],
        ['SOUL.md', claw.openclaw.soul_md === null ? '?' : claw.openclaw.soul_md ? '✓' : '✗'],
        ['MCP', claw.openclaw.mcp_support === null ? '?' : claw.openclaw.mcp_support ? '✓' : '✗'],
        ['技能商店', claw.openclaw.skills_store === null ? '?' : claw.openclaw.skills_store ? '✓' : '✗'],
        ...(claw.openclaw.openclaw_lag_days !== null ? [['落后天数', `${claw.openclaw.openclaw_lag_days}d`]] : []),
      ].map(([k, v]) => (
        <div style="display:flex;justify-content:space-between;padding:0.35rem 0;border-bottom:1px solid var(--sl-color-hairline-light);font-size:0.85rem">
          <span style="color:var(--sl-color-gray-3)">{k}</span>
          <span style="color:var(--sl-color-gray-1);font-weight:500">{v}</span>
        </div>
      ))}
    </div>

    <div style="border:1px solid var(--sl-color-hairline);border-radius:0.75rem;padding:1.25rem">
      <h3 style="margin:0 0 1rem;font-size:0.95rem">支持模型</h3>
      {claw.models.supported.length > 0 ? (
        <div style="display:flex;flex-wrap:wrap;gap:0.4rem">
          {claw.models.supported.map(m => (
            <span style={`font-size:0.78rem;padding:0.2rem 0.6rem;border-radius:0.4rem;border:1px solid ${m === claw.models.default ? 'var(--sl-color-accent)' : 'var(--sl-color-hairline)'};color:${m === claw.models.default ? 'var(--sl-color-accent)' : 'var(--sl-color-gray-3)'}`}>
              {m}{m === claw.models.default ? ' ★' : ''}
            </span>
          ))}
        </div>
      ) : (
        <p style="color:var(--sl-color-gray-5);font-size:0.85rem">暂无数据</p>
      )}
      {claw.models.local_model === true && (
        <p style="font-size:0.8rem;color:#4ade80;margin-top:0.75rem">✓ 支持本地模型</p>
      )}
    </div>

    <div style="border:1px solid var(--sl-color-hairline);border-radius:0.75rem;padding:1.25rem">
      <h3 style="margin:0 0 1rem;font-size:0.95rem">基本信息</h3>
      {[
        ['分类', claw.category],
        ['部署', claw.deployment],
        ...(claw.release_date ? [['发布', claw.release_date]] : []),
        ['最后更新', claw.last_updated],
        ['状态', claw.verified ? '✓ 已验证' : '待验证'],
      ].map(([k, v]) => (
        <div style="display:flex;justify-content:space-between;padding:0.35rem 0;border-bottom:1px solid var(--sl-color-hairline-light);font-size:0.85rem">
          <span style="color:var(--sl-color-gray-3)">{k}</span>
          <span style="color:var(--sl-color-gray-1)">{v}</span>
        </div>
      ))}
    </div>

  </div>

  {notes && (
    <div style="margin-top:1.5rem;border:1px solid var(--sl-color-hairline);border-radius:0.75rem;padding:1.25rem">
      <h3 style="margin:0 0 0.75rem;font-size:0.95rem">备注</h3>
      <p style="color:var(--sl-color-gray-2);font-size:0.85rem;margin:0">{notes}</p>
    </div>
  )}

  {claw.tags.length > 0 && (
    <div style="margin-top:1rem;display:flex;flex-wrap:wrap;gap:0.4rem">
      {claw.tags.map(t => (
        <span style="font-size:0.75rem;color:var(--sl-color-gray-5);border:1px solid var(--sl-color-hairline);border-radius:0.35rem;padding:0.15rem 0.5rem">#{t}</span>
      ))}
    </div>
  )}

</StarlightPage>
